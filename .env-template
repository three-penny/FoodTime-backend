# FoodTime Backend 环境变量模板
# 复制此文件为 .env 并根据实际情况填写

# ---- Flask ----
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
APP_ENV=development

# ---- 密钥 ----
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-must-be-32bytes
JWT_EXPIRATION_HOURS=24

# ---- 数据库 ----
DATABASE_URL=sqlite:///app_dev.db

# ---- 邮箱 (SMTP) ----
# 用于发送注册验证码，推荐使用 QQ 邮箱 SMTP
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-smtp-authorization-code
MAIL_DEFAULT_SENDER=your-email@qq.com

# ---- 验证码 ----
VERIFICATION_CODE_EXPIRE_SECONDS=300

# ---- Redis (验证码存储) ----
# 支持 redis:// 或 rediss:// (TLS) 协议，默认本地 6379
# 留空则使用 redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ---- OpenAI (可选) ----
OPENAI_API_KEY=
